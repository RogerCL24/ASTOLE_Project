# ---------------------------
# LLM providers
# ---------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---------------------------
# LiteLLM model routing
# ---------------------------
ROUTER_MODEL=gpt-4o-mini
SKILL_MODEL=claude-3-5-haiku-20241022
SUMMARIZER_MODEL=gpt-4o-mini
LITELLM_VERBOSE=false

# ---------------------------
# External RAG layer
# ---------------------------
RAG_API_URL=http://localhost:8001
RAG_TOP_K=5
RAG_TIMEOUT_S=5
RAG_RETRIES=2
RAG_USE_MOCK=false

# ---------------------------
# LangSmith tracing
# ---------------------------
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=astole-triage

# ---------------------------
# API server
# ---------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# ---------------------------
# Optional cache
# ---------------------------
CACHE_ENABLED=false
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_S=60
